# Certificates configuration generated from template
#
# Each certificate/key is uploaded to tls/certs, tls/key or tls/ca and
# configured here. CA directories are stored under tls/ca.

certificates {
  # Certificate
  x509 "MANAGEMENT_API_CERT" {
    filename "<root>/management/tls/certs/MANAGEMENT_API_CERT.pem";
  }

  # Private key &lt;root&gt;/management/tls/keys/MANAGEMENT_API_KEY.pem
  key "MANAGEMENT_API_KEY" {
    filename "<root>/management/tls/keys/MANAGEMENT_API_KEY.pem";
    password "whatever";
  }


}
